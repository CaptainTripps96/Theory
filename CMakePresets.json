{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug App",
      "description": "Debug desktop app build with tests enabled.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TSQ_BUILD_APP": "ON",
        "TSQ_BUILD_TESTS": "ON",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release App",
      "description": "Release desktop app build with tests enabled.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "TSQ_BUILD_APP": "ON",
        "TSQ_BUILD_TESTS": "ON",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "tests",
      "displayName": "Headless Core Tests",
      "description": "Build only JUCE/Tracktion-free core tests. Requires Catch2, but no plugin or audio hardware.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/tests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TSQ_BUILD_APP": "OFF",
        "TSQ_BUILD_TESTS": "ON",
        "BUILD_TESTING": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "targets": [
        "tsq_app"
      ]
    },
    {
      "name": "release",
      "configurePreset": "release",
      "targets": [
        "tsq_app"
      ]
    },
    {
      "name": "tests",
      "configurePreset": "tests",
      "targets": [
        "tsq_core_tests"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "tests",
      "configurePreset": "tests",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
